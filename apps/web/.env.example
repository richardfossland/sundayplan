# Local Supabase (from `supabase status`). Copy to .env.local.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# SundayStage import endpoint for the "Send til Stage" action (server-only).
# Defaults to the prod endpoint when unset.
STAGE_IMPORT_URL=https://stage.sundaysuite.app/api/sessions/import-serviceplan
