# Server secret for signing magic-link JWTs. MUST be distinct from the Supabase
# JWT secret. Generate a strong value for staging/prod (e.g. `openssl rand -hex 32`)
# and set it via `supabase secrets set MAGICLINK_SECRET=...`.
# Copy this file to `.env` for local `supabase functions serve`.
MAGICLINK_SECRET=local-dev-magic-link-secret-change-me
