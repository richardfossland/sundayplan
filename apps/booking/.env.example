# Supabase (shared SundayPlan project). Copy to .env.local for local dev.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# SERVER-ONLY. All booking writes go through the service-role RPCs in API routes.
# In production set as a Worker secret: npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Production only — cross-subdomain SSO cookie (shares login across *.sundaysuite.app).
# Leave UNSET locally (localhost has no parent domain).
# NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app

# Where the sign-in fallback sends users (SundaySuite account / SundayPlan).
# NEXT_PUBLIC_PLAN_URL=https://plan.sundaysuite.app/sign-in
