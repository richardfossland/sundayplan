# Supabase (shared SundayPlan project). Copy to .env.local for local dev.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# SERVER-ONLY. All booking writes go through the service-role RPCs in API routes.
# In production set as a Worker secret: npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Production only — cross-subdomain SSO cookie (shares login across *.sundaysuite.app).
# Leave UNSET locally (localhost has no parent domain).
# NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app

# Where the sign-in fallback sends users (SundaySuite account / SundayPlan).
# NEXT_PUBLIC_PLAN_URL=https://plan.sundaysuite.app/sign-in

# SERVER-ONLY. Signs/verifies the no-account renter status magic-links
# (/r/<token>). MUST match the secret the rest of SundayPlan uses (apps/web's
# RSVP path reads the same var) so links are consistent across the suite. Without
# it the rental flow still creates bookings but cannot mint a status link (it
# FLAGS linkIssued:false in the API response).
# MAGICLINK_SECRET=...

# Public base URL used to build absolute status links in comms (SMS/email).
# NEXT_PUBLIC_BOOKING_URL=https://booking.sundaysuite.app

# OPTIONAL comms providers. Without these the SDK uses a keyless STUB provider
# (no network, nothing crashes) — going live is pasting these in, not code changes.
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=...
# RESEND_API_KEY=...
